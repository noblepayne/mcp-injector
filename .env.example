# mcp-injector environment configuration

# --- Required ---
# 32-byte secret for signing conversation history footers.
# Generate with: openssl rand -hex 32
INJECTOR_HMAC_SECRET=replace-with-a-real-32-byte-secret-key-here

# --- Optional ---
# Directory for durable session logs (default: .injector/sessions)
# INJECTOR_DATA_DIR=.injector/sessions

# Server bind address (default: 127.0.0.1)
# MCP_INJECTOR_HOST=127.0.0.1

# Server port (default: 8080)
# MCP_INJECTOR_PORT=8080

# LLM Gateway endpoint (default: http://localhost:11434)
# MCP_INJECTOR_LLM_URL=http://localhost:11434

# Log level: debug|info|warn|error
# MCP_INJECTOR_LOG_LEVEL=info

# Max iterations in tool loop (default: 10)
# MCP_INJECTOR_MAX_ITERATIONS=10

# PII salt secret (if not set, a random one is generated on startup)
# MCP_INJECTOR_PII_SECRET=some-stable-secret-for-tokens

# Audit log HMAC secret (highly recommended)
# MCP_INJECTOR_AUDIT_SECRET=your-audit-signing-secret

# Truncation limit for tool results in bytes (default: 8192)
# MCP_INJECTOR_TRUNCATION_LIMIT=8192
