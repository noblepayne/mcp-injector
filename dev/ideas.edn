 {:id :async-session-wakeup
  :title "Async MCP Task Session Wake-up"
  :description "Injector tracks background tasks; when a task completes, it 'wakes up' the next turn in the same session with the result, avoiding external webhooks."
  :status :exploring
  :created "2026-03-20"
  :complexity :medium
  :value :high
  :notes ["Requires session-id persistence (already in storage.clj)"
          "Need a 'pending-results' queue per session"
          "Flow: User triggers async op → continues chatting → op completes → injector buffers result → next user turn → injector injects context: 'Your earlier request finished: <result>'"]}

 {:id :acp-remote-hands
  :title "ACP Tool Registration & Remote Hands"
  :description "Present ACP endpoints (Remote VPS, other agents) as native tools. Allow the bot to 'register' new ACP hosts and control them like local avatars. Yap could itself be an ACP endpoint."
  :status :exploring
  :created "2026-03-20"
  :complexity :high
  :value :high
  :notes ["Aligns with LF A2A / OpenClaw ACP standards"
          "Remote Hands tool: bot can 'ask for help' or 'delegate to human'"
          "ACP Registration: bot registers new endpoints as injectable tools"
          "Reference: GongRzhe/ACP-MCP-Server for bridge patterns"]}

 {:id :context-awareness-engine
  :title "Context Awareness Engine (503 → Compaction)"
  :description "When virtual model chain hits 503 (context overflow), instead of advancing to next provider (same context window), invoke a lightweight compactor model, then retry original provider."
  :status :exploring
  :created "2026-03-20"
  :complexity :high
  :value :medium
  :notes ["Proposed in TODO.md with partial spec"
          "Alternative: let upstream agents (OpenClaw) handle compaction via session reset"
          "Worth revisiting when we have operator feedback on context overflow rates"]}

