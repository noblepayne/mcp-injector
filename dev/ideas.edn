 {:id :injector-push-mode
  :title "Native Injector Push Mode"
  :description "Move the 'meta-turn' logic (keep-working/done tools) from yap into the injector core. Ensure agents don't get lazy/stop prematurely. Injector-level heartbeat to detect lazy LLM transitions and force re-prompt."
  :status :interested
  :created "2026-03-20"
  :complexity :low
  :value :medium
  :notes ["Makes push-mode available to any client (not just yap)"
          "Useful for long-running research loops"
          "Could add X-Injector-Meta-Turns header to track pushes"]}

 {:id :mcp-search-list-tools
  :title "Native Tool Discovery Tools"
  :description "Expose list_mcp_tools and search_mcp_tools as native tools to the agent, reducing initial prompt bloat. Agent calls them first → narrows → then get_tool_schema."
  :status :interested
  :created "2026-03-20"
  :complexity :low
  :value :high
  :notes ["Already in TODO.md inbox"
          "Also consider: auto-schema on first call (skip explicit get_tool_schema)"]}

 {:id :streaming-tool-results
  :title "Stream Tool Results During Execution"
  :description "Instead of buffering all tool results until the loop completes, stream them back as each tool finishes. Provides real-time progress feedback during long agent loops."
  :status :interested
  :created "2026-03-20"
  :complexity :medium
  :value :medium
  :notes ["Would require non-blocking SSE sending from agent-loop"
          "Verify operators want this before building (YAGNI)"]}

